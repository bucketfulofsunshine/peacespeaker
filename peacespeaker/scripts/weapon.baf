        DisplayStringHeadOwner("sw2h14",2308)  // Hands up, kiddies. Who wants to die?!
    RESPONSE #10
        DisplayStringHeadOwner("sw2h14",2389)  // Mmm-mmm! tastes like chicken!
    RESPONSE #10
