IF
    Delay(125)
    !CombatCounter(0)
    OR(6)
        HasItemEquipedReal("BFSSW",Player1)  
        HasItemEquipedReal("BFSSW",Player2)  
        HasItemEquipedReal("BFSSW",Player3)  
        HasItemEquipedReal("BFSSW",Player4)  
        HasItemEquipedReal("BFSSW",Player5)  
        HasItemEquipedReal("BFSSW",Player6)  
THEN
    RESPONSE #10
        DisplayStringHeadOwner("sw2h14",839)  // You deal—I'll cut! Hahaha!
